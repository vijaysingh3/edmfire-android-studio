<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="#51535C"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ==================== HEADER SECTION ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Transaction Type Icon -->
            <ImageView
                android:id="@+id/ivTransactionIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                tools:src="@drawable/ic_transaction_default" />

            <!-- Transaction Type and Status -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTransactionType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transaction Type"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTransactionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/bg_status_pill"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="Completed"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    tools:text="Completed" />

            </LinearLayout>

            <!-- Amount/Coins Display -->
            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹100"
                android:textColor="#4CAF50"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="₹100" />

        </LinearLayout>

        <!-- ==================== CONTENT SECTION ==================== -->
        <LinearLayout
            android:id="@+id/contentSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Dynamic Content Row 1 -->
            <LinearLayout
                android:id="@+id/row1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UTR:"
                    android:textColor="#B0B0B0"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvUtr"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="528225641548"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    tools:text="528225641548" />

            </LinearLayout>

            <!-- Dynamic Content Row 2 -->
            <LinearLayout
                android:id="@+id/row2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="From:"
                    android:textColor="#B0B0B0"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvPayerInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="Amirsay (BHIM)"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    tools:text="Amirsay (BHIM)" />

            </LinearLayout>

            <!-- Description Row (For Tournament/Referral) -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Joined ClashSquad tournament - ID: EDM_107, Slot: 6"
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="Joined ClashSquad tournament - ID: EDM_107, Slot: 6" />

            <!-- Transaction ID Row (For Withdrawal) -->
            <LinearLayout
                android:id="@+id/rowTransactionId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Txn ID:"
                    android:textColor="#B0B0B0"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvTransactionId"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="VE3F17GD4MUDZ4WA"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    tools:text="VE3F17GD4MUDZ4WA" />

            </LinearLayout>

            <!-- Notes Row (For Withdrawal) -->
            <TextView
                android:id="@+id/tvNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Withdrawal request submitted - pending admin approval"
                android:textColor="#FF9800"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="Withdrawal request submitted - pending admin approval" />

        </LinearLayout>

        <!-- ==================== FOOTER SECTION ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Timestamp -->
            <TextView
                android:id="@+id/tvTimestamp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="09 Oct 2025, 10:15 AM"
                android:textColor="#888888"
                android:textSize="11sp"
                tools:text="09 Oct 2025, 10:15 AM" />

            <!-- Additional Info (Referral Bonus, etc.) -->
            <TextView
                android:id="@+id/tvAdditionalInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Referral Bonus: 2"
                android:textColor="#9C27B0"
                android:textSize="10sp"
                android:visibility="gone"
                tools:text="Referral Bonus: 2" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>