<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardLeaderboardItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/transparent">

    <LinearLayout
        android:id="@+id/layoutItemBg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:background="#1A1A2E">

        <!-- Rank Badge -->
        <TextView
            android:id="@+id/tvRankEmoji"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="🎖️"
            android:textSize="14sp" />

        <!-- User Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <!-- InGameName (Player Name) -->
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player Name"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- ✅ NEW: InGameUID -->
            <TextView
                android:id="@+id/tvInGameUID"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UID: 000000"
                android:textColor="#888888"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>

            <!-- ✅ NEW: InGameLevel -->
            <TextView
                android:id="@+id/tvInGameLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lv. 0"
                android:textColor="#64B5F6"
                android:textSize="10sp"
                android:layout_marginTop="1dp"/>

        </LinearLayout>

        <!-- Stats -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Match Played -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/tvMatchPlayed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Played"
                    android:textColor="#888888"
                    android:textSize="9sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Winning Count -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/tvWinningCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wins"
                    android:textColor="#888888"
                    android:textSize="9sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Winning Coins -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvWinningCoins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coins"
                    android:textColor="#888888"
                    android:textSize="9sp"
                    android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>