<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    tools:context=".LoginActivity">

    <!-- ════════════════════════════════════════
         MAIN SCROLL CONTENT
         ════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Back Button -->
            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/baseline_arrow_back_24"
                android:background="#1A00E5FF"
                android:padding="8dp"
                app:tint="#00E5FF" />

            <!-- App Logo -->
            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:layout_marginBottom="12dp"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/applogo" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="4dp"
                android:fontFamily="@font/alice"
                android:text="WELCOME BACK"
                android:textColor="#00E5FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="Sign in to continue your gaming journey"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:lineSpacingExtra="4sp" />

            <!-- Neon Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="#1A00E5FF"
                android:layout_marginBottom="20dp"/>

            <!-- ── MAIN LOGIN CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D0D1F"
                app:cardCornerRadius="16dp"
                app:strokeColor="#2200E5FF"
                app:strokeWidth="1.5dp"
                app:cardElevation="12dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Email Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📧  EMAIL ADDRESS"
                        android:textColor="#00E5FF"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="6dp"/>

                    <!-- Email Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEmail"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email Address"
                        app:boxBackgroundColor="#0A0A1A"
                        app:boxStrokeColor="#00E5FF"
                        app:boxStrokeWidth="1.5dp"
                        app:hintTextColor="#8000E5FF"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:imeOptions="actionNext"
                            android:inputType="textEmailAddress"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#5000E5FF"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Gmail Picker Button — Optional -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickGmail"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="📬  Pick Gmail from device"
                        android:textColor="#00E5FF"
                        android:textSize="11sp"
                        android:letterSpacing="0.04"
                        android:layout_gravity="end"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="16dp"
                        app:backgroundTint="#0D00E5FF"
                        app:cornerRadius="8dp"
                        app:strokeColor="#2200E5FF"
                        app:strokeWidth="1dp"
                        app:rippleColor="#2200E5FF"
                        app:icon="@null"/>

                    <!-- Password Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒  PASSWORD"
                        android:textColor="#00E5FF"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="6dp"/>

                    <!-- Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPassword"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Password"
                        app:boxBackgroundColor="#0A0A1A"
                        app:boxStrokeColor="#00E5FF"
                        app:boxStrokeWidth="1.5dp"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#4000E5FF"
                        app:hintTextColor="#8000E5FF"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#5000E5FF"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Forgot Password -->
                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:text="Forgot Password?"
                        android:textColor="#FFD700"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- Login Button — Gaming Primary -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:fontFamily="@font/aclonica"
                        android:text="⚡  LOG IN"
                        android:textColor="#0A0A1A"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        app:backgroundTint="#00E5FF"
                        app:cornerRadius="12dp"
                        app:elevation="8dp"
                        app:rippleColor="#40FFFFFF"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── PROCESS STATUS CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProcess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                app:cardBackgroundColor="#0D0D1F"
                app:cardCornerRadius="12dp"
                app:strokeColor="#22FFD700"
                app:strokeWidth="1dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <!-- Gaming Linear Progress -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="true"
                        app:indicatorColor="#00E5FF"
                        app:trackColor="#1A00E5FF"
                        app:trackCornerRadius="4dp" />

                    <!-- Process Step Text -->
                    <TextView
                        android:id="@+id/tvProcessStep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔄  Signing In..."
                        android:textColor="#00E5FF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                    <!-- Process Detail -->
                    <TextView
                        android:id="@+id/tvProcessDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Please wait, do not press back"
                        android:textColor="#60FFFFFF"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Sign Up Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account? "
                    android:textColor="#60FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvSignUp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIGN UP"
                    android:textColor="#00E5FF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ════════════════════════════════════════
         SUCCESS OVERLAY
         ════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutSuccess"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#F00A0A1A"
        android:visibility="gone"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Success Icon -->
        <ImageView
            android:id="@+id/ivSuccess"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_completed"
            android:layout_marginBottom="20dp"/>

        <!-- Success Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOGIN SUCCESS!"
            android:textColor="#00E5FF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <!-- Welcome Text -->
        <TextView
            android:id="@+id/tvWelcomeUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome back, Player!"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="12dp"/>

        <!-- Neon Divider -->
        <View
            android:layout_width="80dp"
            android:layout_height="2dp"
            android:background="#00E5FF"
            android:layout_marginBottom="20dp"/>

        <!-- Auto redirect info -->
        <TextView
            android:id="@+id/tvRedirectInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Redirecting to game..."
            android:textColor="#40FFD700"
            android:textSize="12sp"
            android:gravity="center"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>