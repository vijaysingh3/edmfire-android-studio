<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <!-- ════════════════════════════════════════
         MAIN CONTENT (OTP + Password Entry)
         ════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- ── TOP ICON ── -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/baseline_arrow_back_24"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="6dp"
                app:tint="#FFD700" />

            <!-- ── TITLE ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OTP VERIFICATION"
                android:textColor="#00E5FF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <!-- ── EMAIL INFO ── -->
            <TextView
                android:id="@+id/tvEmailInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OTP sent to your email"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- ── NEON DIVIDER ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="#2200E5FF"
                android:layout_marginBottom="24dp"/>

            <!-- ── MAIN CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOtp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D0D1F"
                app:cardCornerRadius="16dp"
                app:strokeColor="#2200E5FF"
                app:strokeWidth="1.5dp"
                app:cardElevation="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- OTP Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔑  ENTER OTP CODE"
                        android:textColor="#FFD700"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp"/>

                    <!-- OTP Field — PRO LEVEL centered -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilOtp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxStrokeColor="#FFD700"
                        app:boxStrokeWidth="2dp"
                        app:boxBackgroundColor="#0A0A14"
                        app:hintTextColor="#80FFD700"
                        app:counterEnabled="true"
                        app:counterMaxLength="6"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:startIconDrawable="@drawable/baseline_arrow_back_24"
                        app:startIconTint="#FFD700">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etOtp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter 6-digit OTP"
                            android:inputType="numberPassword"
                            android:maxLength="6"
                            android:textColor="#FFD700"
                            android:textColorHint="#50FFD700"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.35"
                            android:gravity="center"
                            android:paddingVertical="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- OTP Timer Hint -->
                    <TextView
                        android:id="@+id/tvOtpTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⏱  OTP valid for 5 minutes"
                        android:textColor="#50FFD700"
                        android:textSize="11sp"
                        android:gravity="end"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="20dp"/>

                    <!-- Password Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒  NEW PASSWORD"
                        android:textColor="#00E5FF"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp"/>

                    <!-- Password Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNewPassword"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxStrokeColor="#00E5FF"
                        app:boxStrokeWidth="1.5dp"
                        app:boxBackgroundColor="#0A0A14"
                        app:hintTextColor="#8000E5FF"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="#4000E5FF"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:startIconDrawable="@drawable/baseline_arrow_back_24"
                        app:startIconTint="#00E5FF">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="New Password (min 6 chars)"
                            android:inputType="textPassword"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#5000E5FF"
                            android:paddingVertical="14dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Strength Hint -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💡  Use uppercase, numbers &amp; symbols for strong password"
                        android:textColor="#4000E5FF"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="24dp"/>

                    <!-- ── VERIFY BUTTON ── Gaming Primary -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerify"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="⚡  VERIFY &amp; RESET PASSWORD"
                        android:textColor="#0A0A1A"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        app:backgroundTint="#00E5FF"
                        app:cornerRadius="12dp"
                        app:elevation="8dp"
                        app:rippleColor="#40FFFFFF"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── PROCESS STATUS CARD ── (Always visible, animates) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProcess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#0D0D1F"
                app:cardCornerRadius="12dp"
                app:strokeColor="#22FFD700"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <!-- Progress Indicator -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="true"
                        app:indicatorColor="#00E5FF"
                        app:trackColor="#1A00E5FF"
                        app:trackCornerRadius="4dp" />

                    <!-- Step Label -->
                    <TextView
                        android:id="@+id/tvProcessStep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔄  Verifying OTP..."
                        android:textColor="#00E5FF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                    <!-- Step Detail -->
                    <TextView
                        android:id="@+id/tvProcessDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Please wait, do not press back"
                        android:textColor="#60FFFFFF"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom spacing -->
            <View
                android:layout_width="match_parent"
                android:layout_height="32dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ════════════════════════════════════════
         SUCCESS OVERLAY (shown after reset done)
         ════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutSuccess"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#F00A0A1A"
        android:visibility="gone"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Success Icon -->
        <ImageView
            android:id="@+id/ivSuccess"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_completed"
            android:layout_marginBottom="20dp"/>

        <!-- Success Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASSWORD RESET!"
            android:textColor="#00E5FF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <!-- Success Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your password has been successfully\nupdated. You can now login."
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="32dp"/>

        <!-- Neon Divider -->
        <View
            android:layout_width="80dp"
            android:layout_height="2dp"
            android:background="#00E5FF"
            android:layout_marginBottom="32dp"/>

        <!-- Go to Login Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToLogin"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="🚀  GO TO LOGIN"
            android:textColor="#0A0A1A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            app:backgroundTint="#00E5FF"
            app:cornerRadius="12dp"
            app:elevation="8dp"
            app:rippleColor="#40FFFFFF"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>