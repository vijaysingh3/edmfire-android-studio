<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient">

    <!-- Loading ProgressBar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:visibility="gone" />

    <!-- Chat Info Text -->
    <TextView
        android:id="@+id/tvChatInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:gravity="center"
        android:padding="8dp"
        android:text="Chat with tournament players"
        android:textColor="#00FFCC"
        android:textSize="12sp"
        android:visibility="visible" />

    <!-- Reply Preview -->
    <LinearLayout
        android:id="@+id/replyPreviewLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#2A2A2A"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvReplyPreview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Replying to user: Message preview"
            android:textColor="#00FFCC"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:padding="4dp" />

        <ImageButton
            android:id="@+id/btnCancelReply"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_close"
            android:scaleType="center"
            android:padding="2dp" />

    </LinearLayout>

    <!-- Empty State Message -->
    <TextView
        android:id="@+id/tvEmptyMessage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No messages yet. Be the first to chat!"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- RecyclerView for Chat Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="4dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        android:visibility="visible" />

    <!-- Message Input Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_chat_input"
        android:padding="8dp">

        <!-- EditText for message -->
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:enabled="false"
            android:hint="Join tournament to send messages"
            android:maxLines="3"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#CCCCCC" />

        <!-- 🔥 Character Count and Send Button Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <!-- Character Counter -->
            <TextView
                android:id="@+id/tvCharCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0/600"
                android:textSize="11sp"
                android:textColor="#888888"
                android:paddingStart="12dp" />

            <!-- Send Button -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_neon_button"
                android:enabled="false"
                android:padding="10dp"
                android:scaleType="center"
                android:src="@drawable/ic_send"
                android:layout_marginEnd="8dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>