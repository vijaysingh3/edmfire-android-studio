<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gaming_bg_gradient"
    android:orientation="vertical">

    <!-- Gradient Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0"
        android:background="@drawable/gaming_overlay" />

    <!-- ==================== TOP BAR ==================== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1A1A2E"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/btn_back_bg"
                android:contentDescription="Back"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back" />

            <!-- Agent Icon -->
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:contentDescription="Agent"
                android:padding="4dp"
                android:src="@drawable/ic_edm_agent" />

            <!-- Name + Status -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EDM Fire Agent"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Connecting..."
                    android:textColor="#FFA500"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- AI Active Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/status_badge"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp">

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/online_dot" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Active"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ==================== UNREGISTERED USER BANNER ==================== -->
    <LinearLayout
        android:id="@+id/bannerUnregistered"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A6C63FF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Signup Support Mode — Help for new users"
            android:textColor="#B0B0FF"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- ==================== MESSAGES ==================== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp" />

    <!-- ==================== TYPING INDICATOR ==================== -->
    <LinearLayout
        android:id="@+id/typingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/typing_bubble"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EDM Fire Agent is typing"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="8dp"
            android:alpha="0.5"
            android:background="@drawable/typing_dot" />
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="3dp"
            android:alpha="0.75"
            android:background="@drawable/typing_dot" />
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="3dp"
            android:background="@drawable/typing_dot" />

    </LinearLayout>

    <!-- ==================== INPUT BAR — Keyboard ke just upar ==================== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        app:cardBackgroundColor="#1E2A3A"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Ask me anything..."
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/send_button_bg"
                android:contentDescription="Send"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_send" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ==================== LOADING OVERLAY ==================== -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0F0C29"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/loading_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="#6C63FF" />

            <TextView
                android:id="@+id/txtLoadingMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Connecting to EDM Fire..."
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>